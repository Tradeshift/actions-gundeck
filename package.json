{
  "name": "@tradeshift/actions-gundeck",
  "version": "0.0.0",
  "private": true,
  "description": "Github action to trigger rundeck jobs w/ mTLS",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tradeshift/actions-gundeck.git"
  },
  "keywords": [
    "actions",
    "node",
    "rundeck"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "1.11.1",
    "@actions/exec": "1.1.1",
    "csv-parse": "4.16.3"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "24.10.0",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@vercel/ncc": "0.38.3",
    "eslint": "8.57.1",
    "eslint-plugin-github": "5.1.8",
    "eslint-plugin-jest": "28.14.0",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.3.0",
    "jest-circus": "30.3.0",
    "prettier": "3.8.1",
    "ts-jest": "29.2.5",
    "typescript": "5.9.2"
  }
}
